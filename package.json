{
  "name": "@kinde/tsr",
  "version": "0.0.2-0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf ./dist && tsup",
    "format": "biome check --write --unsafe",
    "lint": "biome lint"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@tanstack/react-router": "^1.167.8",
    "@tanstack/react-start": "^1.167.8",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.15",
    "@types/react-dom": "^19.1.9",
    "esbuild-plugin-file-path-extensions": "^2.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.167.8",
    "@tanstack/react-start": "^1.167.8"
  },
  "dependencies": {
    "@kinde-oss/kinde-auth-react": "^5.11.0",
    "@kinde/js-utils": "^0.30.0",
    "@kinde/jwt-decoder": "^0.2.0",
    "path-to-regexp": "^8.3.0"
  }
}
