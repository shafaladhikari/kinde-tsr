    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf ./dist && tsup",
    "format": "biome check --write",
    "lint": "biome lint"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@types/node": "^24.5.2",
    "@types/react": "19.1.4",
    "esbuild-plugin-file-path-extensions": "^2.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0"
  },
  "dependencies": {
    "@kinde-oss/kinde-auth-react": "^5.7.0-0",
    "@kinde/js-utils": "^0.25.0-1",
    "@kinde/jwt-decoder": "^0.2.0"
  }
