{
  "$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!playground"
    ]
  },
  "linter": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!playground"
    ],
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  },
  "formatter": {
    "indentStyle": "space", 
    "lineWidth": 100 
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single", 
      "lineWidth": 120 
    }
  },
  "json": {
    "formatter": {
      "enabled": false
    }
  }
}
